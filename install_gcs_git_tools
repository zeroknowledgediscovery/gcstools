#!/usr/bin/env bash
set -euo pipefail

INSTALL_DIR="$HOME/.local/bin"

echo "Installing git-GCS tools into $INSTALL_DIR"

mkdir -p "$INSTALL_DIR"

############################################
# backend engine
############################################

cat > "$INSTALL_DIR/git_gcs_artifacts" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

LOCATION_DEFAULT="US"
STORAGE_CLASS_DEFAULT="STANDARD"

die() { echo "ERROR: $*" >&2; exit 1; }

need_cmd() {
command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

ensure_git_repo() {
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not inside a git repo."
}

repo_root() {
git rev-parse --show-toplevel
}

sanitize() {
echo "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g'
}

git_remote_url() {
git remote get-url origin 2>/dev/null || true
}

infer_org_repo() {

url="$(git_remote_url)"

if [[ -n "$url" ]]; then

case "$url" in
git@*:*/*)
path="${url#*:}"
;;
https://*/*/*)
path="$(echo "$url" | sed -E 's#https://[^/]+/##')"
;;
*)
path=""
;;
esac

if [[ -n "$path" ]]; then
path="${path%.git}"
org="$(echo "$path" | cut -d/ -f1)"
repo="$(basename "$path")"
echo "$(sanitize "$org") $(sanitize "$repo")"
return
fi

fi

repo="$(basename "$(repo_root)")"
echo "local $(sanitize "$repo")"

}

default_bucket() {

read org repo < <(infer_org_repo)

echo "git-${org}-${repo}"

}

sha256_file() {

sha256sum "$1" | awk '{print $1}'

}

ensure_bucket() {

bucket="$1"
uri="gs://$bucket"

if gcloud storage buckets describe "$uri" >/dev/null 2>&1; then
return
fi

echo "Creating bucket $uri"

gcloud storage buckets create "$uri" \
--location "$LOCATION_DEFAULT" \
--default-storage-class "$STORAGE_CLASS_DEFAULT"

}

ensure_gitignore_line() {

line="$1"

touch .gitignore

grep -Fxq "$line" .gitignore 2>/dev/null || echo "$line" >> .gitignore

}

cmd_init() {

ensure_git_repo
need_cmd gcloud

bucket="$(default_bucket)"

ensure_bucket "$bucket"

touch .gitignore

echo "Repo initialized for GCS artifacts"
echo "Bucket: gs://$bucket"

}

cmd_add() {

ensure_git_repo
need_cmd gcloud

path="$1"

[[ -e "$path" ]] || die "Path not found"

bucket="$(default_bucket)"

ensure_bucket "$bucket"

ptr="$path.gcs"

if [[ -f "$path" ]]; then

uri="gs://$bucket/$path"

gcloud storage cp "$path" "$uri"

sha="$(sha256_file "$path")"

cat > "$ptr" <<EOF2
type: file
uri: $uri
sha256: $sha
EOF2

elif [[ -d "$path" ]]; then

uri="gs://$bucket/$path"

gcloud storage cp --recursive "$path" "$uri"

cat > "$ptr" <<EOF2
type: dir
uri: $uri
EOF2

else

die "Unsupported path type"

fi

ensure_gitignore_line "$path"

echo "Pointer written: $ptr"
echo "Added to .gitignore: $path"

}

pull_ptr() {

ptr="$1"

[[ -f "$ptr" ]] || die "Pointer not found: $ptr"

type="$(awk '/^type:/ {print $2}' "$ptr")"
uri="$(awk '/^uri:/ {print $2}' "$ptr")"

out="${ptr%.gcs}"

[[ -n "$type" ]] || die "Missing type in pointer: $ptr"
[[ -n "$uri" ]] || die "Missing uri in pointer: $ptr"

if [[ "$type" == "file" ]]; then

mkdir -p "$(dirname "$out")"

gcloud storage cp "$uri" "$out"

echo "Restored $out"

elif [[ "$type" == "dir" ]]; then

mkdir -p "$out"

gcloud storage rsync --recursive "$uri" "$out"

echo "Restored directory $out"

else

die "Unknown pointer type '$type' in $ptr"

fi

}

pull_dir() {

dir="$1"

find "$dir" -name "*.gcs" | while read -r ptr; do
pull_ptr "$ptr"
done

}

cmd_pull() {

target="$1"

if [[ "$target" == "--all" ]]; then

find . -name "*.gcs" | while read -r ptr; do
pull_ptr "$ptr"
done

elif [[ -f "$target" ]]; then

pull_ptr "$target"

elif [[ -d "$target" ]]; then

pull_dir "$target"

else

die "Invalid pull target"

fi

}

cmd_status() {

find . -name "*.gcs"

}

case "${1:-}" in

init)
shift
cmd_init "$@"
;;

add)
shift
cmd_add "$@"
;;

pull)
shift
cmd_pull "$@"
;;

status)
shift
cmd_status "$@"
;;

*)
echo "Usage: git_gcs_artifacts {init|add|pull|status}"
exit 1
;;

esac

EOF

############################################
# wrappers
############################################

cat > "$INSTALL_DIR/gcsinit" <<'EOF'
#!/usr/bin/env bash
set -e
exec git_gcs_artifacts init "$@"
EOF

cat > "$INSTALL_DIR/gcspush" <<'EOF'
#!/usr/bin/env bash
set -e
[[ $# -ge 1 ]] || { echo "Usage: gcspush PATH"; exit 1; }
exec git_gcs_artifacts add "$1"
EOF

cat > "$INSTALL_DIR/gcspull" <<'EOF'
#!/usr/bin/env bash
set -e

[[ $# -ge 1 ]] || { echo "Usage: gcspull POINTER.gcs | DIR | --all"; exit 1; }

if [[ "$1" == "--all" ]]; then
exec git_gcs_artifacts pull --all
fi

exec git_gcs_artifacts pull "$1"
EOF

cat > "$INSTALL_DIR/gcsstatus" <<'EOF'
#!/usr/bin/env bash
set -e
exec git_gcs_artifacts status "$@"
EOF

############################################
# permissions
############################################

chmod +x "$INSTALL_DIR/git_gcs_artifacts"
chmod +x "$INSTALL_DIR/gcsinit"
chmod +x "$INSTALL_DIR/gcspush"
chmod +x "$INSTALL_DIR/gcspull"
chmod +x "$INSTALL_DIR/gcsstatus"

############################################
# ensure PATH
############################################

if ! echo "$PATH" | grep -q "$INSTALL_DIR"; then
echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc
echo "Added ~/.local/bin to PATH (restart shell)"
fi

echo
echo "Installation complete."
echo
echo "Commands available:"
echo
echo "  gcsinit"
echo "  gcspush <file|dir>"
echo "  gcspull <pointer.gcs|dir|--all>"
echo "  gcsstatus"
echo
echo "Example usage:"
echo
echo "  gcsinit"
echo "  gcspush data/big.parquet"
echo "  gcspull data/big.parquet.gcs"
